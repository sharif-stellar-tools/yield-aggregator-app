# --- Soroban deployment configuration -------------------------------------
# Copy to `.env` (git-ignored) or just export these in your shell.

# Stellar network to deploy to. TESTNET by default.
# This project's deploy script refuses mainnet/public.
STELLAR_NETWORK=testnet

# Stellar client/network helpers. These default to Testnet when unset.
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Name of the stellar-cli identity used as the deploy *source account*.
# Manage it with `stellar keys`. The SECRET key is stored by stellar-cli, never
# in this file. On testnet it is auto-created and funded via Friendbot.
STELLAR_SOURCE=vault-deployer

# --- Populated automatically by scripts/deploy.sh -------------------------
VAULT_CONTRACT_ID=
DEPLOYER_PUBLIC_KEY=
