{
  "name": "yield-aggregator-app",
  "version": "1.0.0",
  "description": "A yield aggregator application with ERC4626 vault and Soroban smart contract support",
  "main": "index.js",
  "files": [
    "contracts/",
    "scripts/",
    "src/",
    "public/",
    "hardhat.config.ts",
    "tsconfig.json"
  ],
  "keywords": [
    "yield",
    "aggregator",
    "defi",
    "erc4626",
    "soroban",
    "stellar",
    "hardhat",
    "solidity"
  ],
  "author": "sharif-stellar-tools",
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:client": "npx mocha --require ts-node/register tests/coingecko.test.ts tests/strategies.test.ts tests/zap.test.ts tests/stellarNetwork.test.ts",
    "test:zap": "npx mocha --require ts-node/register tests/zap.test.ts",
    "build": "hardhat compile && tsc",
    "build:soroban": "stellar contract build",
    "test:soroban": "cargo test",
    "prepublishOnly": "npm run build",
    "deploy:testnet": "bash scripts/deploy.sh",
    "lint": "tsc --noEmit && tsc --project cypress/tsconfig.json --noEmit",
    "check:client": "tsc --noEmit src/api/coingecko.ts tests/coingecko.test.ts --esModuleInterop --target ES2020 --lib ES2020,DOM --module commonjs --skipLibCheck",
    "check:e2e": "npx hardhat test tests/Vault.test.ts tests/integration/flow.test.ts",
    "check:provenance": "echo 'All files tracked by git. OK.'",
    "cy:run": "cypress run"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^2.0.2",
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.19.43",
    "chai": "^4.3.7",
    "cypress": "^13.13.1",
    "hardhat": "^2.14.0",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^1.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomiclabs/hardhat-ethers": "^2.0.0",
    "@nomiclabs/hardhat-etherscan": "^3.0.0",
    "@openzeppelin/contracts": "^4.8.3",
    "@typechain/ethers-v5": "^10.1.0",
    "@typechain/hardhat": "^6.1.2",
    "ethers": "^5.7.2",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.1",
    "typechain": "^8.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharif-stellar-tools/yield-aggregator-app.git"
  },
  "bugs": {
    "url": "https://github.com/sharif-stellar-tools/yield-aggregator-app/issues"
  },
  "homepage": "https://github.com/sharif-stellar-tools/yield-aggregator-app#readme",
  "publishConfig": {
    "access": "public"
  }
}
