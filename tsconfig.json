{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "rootDir": ".",
    "outDir": "dist",
    "resolveJsonModule": true,
    "lib": ["ES2020", "DOM"],
    "types": ["node", "mocha", "chai"]
  },
  "include": [
    "hardhat.config.ts",
    "src/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["cypress", "cypress.config.ts"]
}
